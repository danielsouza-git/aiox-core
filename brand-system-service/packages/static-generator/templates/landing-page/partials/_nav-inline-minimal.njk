{# Navigation Partial: inline-minimal — REBEL-EDGE family (PDL-7) #}
<header class="layout-nav layout-nav--inline-minimal" role="navigation" aria-label="Main navigation">
  <div class="container">
    <nav>
      <ul class="nav-links" role="list">
        {% if nav and nav.links %}
          {% for link in nav.links %}
            <li><a href="{{ link.href }}">{{ link.label }}</a></li>
          {% endfor %}
        {% endif %}
        <li><a href="#main-content">{{ clientId }}</a></li>
      </ul>
    </nav>
  </div>
</header>
