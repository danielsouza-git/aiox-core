{# Navigation Partial: breadcrumb-horizontal — WARM-ARTISAN family (PDL-7) #}
<header class="layout-nav layout-nav--breadcrumb-horizontal" role="navigation" aria-label="Main navigation">
  <div class="container">
    <nav>
      <ul class="nav-links" role="list">
        <li><a href="index.html">{{ clientId }}</a></li>
        {% if nav and nav.links %}
          {% for link in nav.links %}
            <li><a href="{{ link.href }}">{{ link.label }}</a></li>
          {% endfor %}
        {% endif %}
      </ul>
    </nav>
  </div>
</header>
