<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= it.currentPage.title %> - <%= it.title %></title>
  <% if (it.typography && it.typography.meta && it.typography.meta.embedTag) { %>
  <%~ it.typography.meta.embedTag %>
  <% } %>
  <link rel="stylesheet" href="./assets/style.css">
  <script src="https://cdn.jsdelivr.net/npm/fuse.js@7/dist/fuse.min.js" defer></script>
  <script src="./assets/search.js" defer></script>
</head>
<body>
  <input type="checkbox" id="hamburger-toggle" class="hamburger-toggle" aria-hidden="true">

  <header class="mobile-header" role="banner">
    <label for="hamburger-toggle" class="hamburger-label" aria-label="Toggle navigation menu">
      <span></span>
    </label>
    <span class="mobile-header__title"><%= it.brand.clientName %></span>
  </header>

  <div class="page-wrapper">
    <aside class="sidebar" role="navigation" aria-label="Brand book sections">
      <div class="sidebar__brand">
        <img src="./assets/logo.svg" alt="<%= it.brand.clientName %> logo" class="sidebar__logo" width="40" height="40">
        <div class="sidebar__brand-name"><%= it.brand.clientName %></div>
        <% if (it.brand.tagline) { %>
        <div class="sidebar__brand-tagline"><%= it.brand.tagline %></div>
        <% } %>
      </div>

      <div class="search-container" style="position: relative;">
        <label for="brand-search" class="sr-only" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);">Search brand book</label>
        <input type="search" id="brand-search" class="search-input" placeholder="Search..." aria-label="Search brand book">
        <div id="search-results" class="search-results" role="listbox" aria-label="Search results"></div>
      </div>

      <nav>
        <ul role="list">
          <% for (const page of it.pages) { %>
          <li>
            <a href="./<%= page.slug %>.html"<% if (it.currentPage.slug === page.slug) { %> class="active" aria-current="page"<% } %>>
              <%= page.title %>
            </a>
          </li>
          <% } %>
        </ul>
      </nav>
    </aside>

    <main class="main-content" id="main-content" role="main">
      <%~ it.content %>
    </main>
  </div>

  <footer role="contentinfo" style="margin-left: var(--sidebar-width); padding: 24px 64px; border-top: 1px solid var(--color-border); font-size: 13px; color: var(--color-text-secondary);">
    <% if (it.brand.websiteUrl) { %>
    <a href="<%= it.brand.websiteUrl %>"><%= it.brand.clientName %></a> &mdash;
    <% } %>
    Generated by Brand System Service
  </footer>
</body>
</html>
