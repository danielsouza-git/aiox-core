<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Microcopy Guide — {{ microcopy.brandName | default(clientId) }}</title>
  <link rel="stylesheet" href="tokens.css">
  <link rel="stylesheet" href="styles.min.css">
  <style>
    /* Microcopy Guide — supplemental styles */
    .mc-header {
      background: var(--color-primary, #3b82f6);
      color: var(--color-on-primary, #fff);
      padding: 3rem 1.5rem;
      text-align: center;
    }

    .mc-header h1 {
      font-family: var(--font-family-heading, var(--font-family-body, system-ui));
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .mc-header p {
      opacity: 0.9;
      font-size: 1.125rem;
    }

    .mc-toc {
      max-width: 800px;
      margin: 2rem auto;
      padding: 1.5rem;
      background: var(--color-surface-secondary, #f3f4f6);
      border-radius: var(--border-radius-md, 8px);
    }

    .mc-toc h2 {
      font-size: 1.125rem;
      margin-bottom: 0.75rem;
    }

    .mc-toc ol {
      padding-left: 1.5rem;
    }

    .mc-toc li { margin-bottom: 0.375rem; }

    .mc-toc a {
      color: var(--color-primary, #3b82f6);
      text-decoration: none;
    }

    .mc-toc a:hover { text-decoration: underline; }

    .mc-content {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    .mc-section {
      margin-bottom: 3rem;
    }

    .mc-section h2 {
      font-family: var(--font-family-heading, var(--font-family-body, system-ui));
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--color-text-primary, #1a1a1a);
      border-bottom: 2px solid var(--color-primary, #3b82f6);
      padding-bottom: 0.5rem;
      margin-bottom: 1.5rem;
    }

    .mc-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9375rem;
    }

    .mc-table th {
      text-align: left;
      padding: 0.75rem 1rem;
      background: var(--color-surface-secondary, #f3f4f6);
      font-weight: 600;
      border-bottom: 1px solid var(--color-border, #e5e7eb);
    }

    .mc-table td {
      padding: 0.75rem 1rem;
      border-bottom: 1px solid var(--color-border, #e5e7eb);
      vertical-align: top;
    }

    .mc-table tr:hover td {
      background: var(--color-surface-hover, #f9fafb);
    }

    .mc-copy-text {
      font-family: var(--font-family-mono, monospace);
      font-size: 0.875rem;
      background: var(--color-surface-secondary, #f3f4f6);
      padding: 0.25rem 0.5rem;
      border-radius: 4px;
    }

    .mc-notes {
      font-size: 0.8125rem;
      color: var(--color-text-tertiary, #9ca3af);
      font-style: italic;
    }

    .mc-footer {
      text-align: center;
      padding: 2rem;
      font-size: 0.75rem;
      color: var(--color-text-tertiary, #9ca3af);
    }
  </style>
</head>
<body>
  <header class="mc-header">
    <h1>Microcopy Guide</h1>
    <p>{{ microcopy.brandName | default(clientId) }} — {{ microcopy.totalItems | default(0) }} items across {{ microcopy.sections.length | default(0) }} sections</p>
  </header>

  <nav class="mc-toc">
    <h2>Table of Contents</h2>
    <ol>
      {% for section in microcopy.sections %}
      <li><a href="#{{ section.slug }}">{{ section.title }}</a> ({{ section.items.length }})</li>
      {% endfor %}
    </ol>
  </nav>

  <main class="mc-content">
    {% for section in microcopy.sections %}
    <section class="mc-section" id="{{ section.slug }}">
      <h2>{{ section.title }}</h2>
      <table class="mc-table">
        <thead>
          <tr>
            <th>Context</th>
            <th>Copy</th>
            <th>Notes</th>
          </tr>
        </thead>
        <tbody>
          {% for item in section.items %}
          <tr>
            <td>{{ item.context }}</td>
            <td><span class="mc-copy-text">{{ item.copy }}</span></td>
            <td>{% if item.notes %}<span class="mc-notes">{{ item.notes }}</span>{% endif %}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>
    {% endfor %}
  </main>

  <footer class="mc-footer">
    Generated by Brand System Service — {{ currentYear | default('2026') }}
  </footer>
</body>
</html>
