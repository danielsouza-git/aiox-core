{
  "borderRadius": {
    "sm": {
      "$value": "4px",
      "$type": "dimension",
      "$description": "Small radius for buttons and inputs"
    },
    "md": {
      "$value": "8px",
      "$type": "dimension",
      "$description": "Medium radius for cards and containers"
    },
    "lg": {
      "$value": "12px",
      "$type": "dimension",
      "$description": "Large radius for modals and popovers"
    },
    "xl": {
      "$value": "24px",
      "$type": "dimension",
      "$description": "Extra-large radius for pills and tags"
    },
    "full": {
      "$value": "9999px",
      "$type": "dimension",
      "$description": "Full radius for circles and rounded elements"
    }
  },
  "shadow": {
    "sm": {
      "$value": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
      "$type": "shadow",
      "$description": "Small shadow for subtle elevation (buttons, inputs)"
    },
    "md": {
      "$value": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)",
      "$type": "shadow",
      "$description": "Medium shadow for cards and dropdowns"
    },
    "lg": {
      "$value": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)",
      "$type": "shadow",
      "$description": "Large shadow for modals and floating panels"
    }
  },
  "motion": {
    "duration": {
      "fast": {
        "$value": "100ms",
        "$type": "duration",
        "$description": "Fast transitions — micro-interactions, hover effects"
      },
      "normal": {
        "$value": "200ms",
        "$type": "duration",
        "$description": "Normal transitions — standard UI state changes"
      },
      "slow": {
        "$value": "300ms",
        "$type": "duration",
        "$description": "Slow transitions — modals, page transitions"
      },
      "slower": {
        "$value": "500ms",
        "$type": "duration",
        "$description": "Slowest transitions — complex animations, reveals"
      }
    },
    "easing": {
      "default": {
        "$value": "ease-in-out",
        "$type": "cubicBezier",
        "$description": "Default easing for most transitions"
      },
      "in": {
        "$value": "ease-in",
        "$type": "cubicBezier",
        "$description": "Ease-in for elements entering view"
      },
      "out": {
        "$value": "ease-out",
        "$type": "cubicBezier",
        "$description": "Ease-out for elements leaving view"
      }
    }
  }
}
