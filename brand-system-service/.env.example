# Brand System Service - Environment Variables
# Copy to .env and fill in values

# =============================================================================
# Cloudflare R2 (Asset Storage) - ADR-004
# =============================================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=brand-assets
R2_PUBLIC_URL=

# =============================================================================
# AI Providers
# =============================================================================

# Anthropic Claude API (primary text generation)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI GPT-4o (fallback text generation + DALL-E 3)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Replicate (Flux 1.1 Pro - image generation)
REPLICATE_API_TOKEN=

# ElevenLabs (voice synthesis for video)
ELEVENLABS_API_KEY=

# =============================================================================
# Email (Resend)
# =============================================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# ClickUp Integration (ADR-002: Operations Hub)
# =============================================================================
CLICKUP_API_KEY=
CLICKUP_WORKSPACE_ID=
CLICKUP_TEAM_ID=

# =============================================================================
# Figma (Token Sync via Tokens Studio)
# =============================================================================
FIGMA_ACCESS_TOKEN=

# =============================================================================
# Monitoring
# =============================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# =============================================================================
# Build Configuration
# =============================================================================

# Default client for local development
BSS_CLIENT_ID=demo
BSS_OUTPUT_DIR=output

# Static hosting target: vercel | netlify | generic
BSS_HOSTING_TARGET=generic

# Enable verbose build logging
BSS_DEBUG=false

# =============================================================================
# Optional: Payload CMS (ADR-007 - only when CMS features needed)
# =============================================================================
# PAYLOAD_SECRET=
# PAYLOAD_MONGODB_URI=
# PAYLOAD_PUBLIC_SERVER_URL=

# =============================================================================
# Optional: Remotion Lambda (video rendering)
# =============================================================================
# REMOTION_AWS_REGION=
# REMOTION_AWS_ACCESS_KEY_ID=
# REMOTION_AWS_SECRET_ACCESS_KEY=

# =============================================================================
# Static Hosting Deployment (CI/CD)
# See README "Setting up GitHub Secrets for CI/CD" section
# =============================================================================
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
