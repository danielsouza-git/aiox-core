{
  "layout": {
    "family": {
      "name": {
        "$value": "ethereal",
        "$type": "string",
        "$description": "Resolved layout family name"
      }
    },
    "corner": {
      "radiusBase": {
        "$value": "12px",
        "$type": "dimension",
        "$description": "Base corner radius for general elements"
      },
      "radiusSmall": {
        "$value": "16px",
        "$type": "dimension",
        "$description": "Small corner radius for compact elements"
      },
      "radiusLarge": {
        "$value": "32px",
        "$type": "dimension",
        "$description": "Large corner radius for hero/card elements"
      }
    },
    "whitespace": {
      "density": {
        "$value": "spacious",
        "$type": "string",
        "$description": "Overall whitespace density category"
      },
      "multiplier": {
        "$value": 1.5,
        "$type": "number",
        "$description": "Whitespace scaling multiplier"
      },
      "sectionGap": {
        "$value": "96px",
        "$type": "dimension",
        "$description": "Vertical gap between major sections"
      },
      "contentPadding": {
        "$value": "80px",
        "$type": "dimension",
        "$description": "Content area padding"
      }
    },
    "nav": {
      "style": {
        "$value": "centered-top",
        "$type": "string",
        "$description": "Navigation layout style"
      },
      "width": {
        "$value": "100%",
        "$type": "string",
        "$description": "Navigation width"
      },
      "height": {
        "$value": "64px",
        "$type": "dimension",
        "$description": "Navigation height"
      }
    },
    "divider": {
      "style": {
        "$value": "organic-wave",
        "$type": "string",
        "$description": "Section divider visual style"
      },
      "height": {
        "$value": "2px",
        "$type": "dimension",
        "$description": "Divider stroke height"
      }
    },
    "animation": {
      "entrance": {
        "$value": "fade-up",
        "$type": "string",
        "$description": "Element entrance animation type"
      },
      "duration": {
        "$value": "300ms",
        "$type": "duration",
        "$description": "Animation duration"
      },
      "easing": {
        "$value": "cubic-bezier(0.25, 0.1, 0.25, 1.0)",
        "$type": "cubicBezier",
        "$description": "Animation easing curve"
      }
    },
    "grid": {
      "rhythm": {
        "$value": "centered-single",
        "$type": "string",
        "$description": "Grid layout rhythm pattern"
      },
      "maxWidth": {
        "$value": "800px",
        "$type": "dimension",
        "$description": "Maximum content width"
      },
      "columns": {
        "$value": 1,
        "$type": "number",
        "$description": "Number of grid columns"
      }
    },
    "section": {
      "background": {
        "$value": "soft-fill",
        "$type": "string",
        "$description": "Section background treatment"
      },
      "heroHeight": {
        "$value": "60vh",
        "$type": "dimension",
        "$description": "Hero section viewport height"
      }
    },
    "component": {
      "cardShape": {
        "$value": "pill",
        "$type": "string",
        "$description": "Card element shape style"
      },
      "shadowIntensity": {
        "$value": "light",
        "$type": "string",
        "$description": "Component shadow depth"
      }
    }
  }
}
