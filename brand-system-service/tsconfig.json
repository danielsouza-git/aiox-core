{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,
    "baseUrl": ".",
    "paths": {
      "@bss/core": ["packages/core/src"],
      "@bss/core/*": ["packages/core/src/*"],
      "@bss/tokens": ["packages/tokens/src"],
      "@bss/tokens/*": ["packages/tokens/src/*"],
      "@bss/creative": ["packages/creative/src"],
      "@bss/creative/*": ["packages/creative/src/*"],
      "@bss/static-generator": ["packages/static-generator/src"],
      "@bss/static-generator/*": ["packages/static-generator/src/*"],
      "@brand-system/ai-service": ["packages/ai-service/src"],
      "@brand-system/ai-service/*": ["packages/ai-service/src/*"],
      "@brand-system/prompts": ["packages/prompts/src"],
      "@brand-system/prompts/*": ["packages/prompts/src/*"],
      "@brand-system/quality": ["packages/quality/src"],
      "@brand-system/quality/*": ["packages/quality/src/*"],
      "@brand-system/cost": ["packages/cost/src"],
      "@brand-system/cost/*": ["packages/cost/src/*"],
      "@brand-system/moderation": ["packages/moderation/src"],
      "@brand-system/moderation/*": ["packages/moderation/src/*"],
      "@brand-system/copy-pipeline": ["packages/copy-pipeline/src"],
      "@brand-system/copy-pipeline/*": ["packages/copy-pipeline/src/*"],
      "@brand-system/onboarding": ["packages/onboarding/src"],
      "@brand-system/onboarding/*": ["packages/onboarding/src/*"]
    }
  },
  "references": [
    { "path": "packages/core" },
    { "path": "packages/tokens" },
    { "path": "packages/creative" },
    { "path": "packages/static-generator" },
    { "path": "packages/ai-service" },
    { "path": "packages/prompts" },
    { "path": "packages/quality" },
    { "path": "packages/cost" },
    { "path": "packages/moderation" },
    { "path": "packages/copy-pipeline" },
    { "path": "packages/onboarding" }
  ],
  "files": [],
  "exclude": ["node_modules", "dist", "output"]
}
